{
  "outputDirectory": ".",
  "functions": {
    "api/clawd-grok-sandbox.js": {
      "maxDuration": 300
    }
  },
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "verify.8bitlabs.ai"
        }
      ],
      "destination": "/solana-redpill-verifier.html",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/solana-redpill-verifier",
      "destination": "/solana-redpill-verifier.html"
    },
    {
      "source": "/model-kit",
      "destination": "/model-kit.html"
    },
    {
      "source": "/model-kit-api/:path*",
      "destination": "https://x402-model-kit-docker-api.onrender.com/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/model-kit-api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
