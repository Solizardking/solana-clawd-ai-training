{
  "id": "clawd-live-mesh-router",
  "name": "Clawd Live Mesh Router",
  "last_confirmed": "2026-06-22",
  "public_surfaces": {
    "mesh_visualizer": "https://mesh.x402.wtf/",
    "inference_mesh": "https://clawd-inference-mesh.fly.dev/",
    "zk_router": "https://clawdrouter-zk.fly.dev/",
    "onchain_chat": "https://onchain.x402.wtf/chat"
  },
  "browser_chat_wiring": {
    "source": "OnChain-Ai-main frontend /chat (Chat.jsx)",
    "env": {
      "INFERENCE_MESH_URL": "https://clawd-inference-mesh.fly.dev"
    },
    "flow": [
      "Browser /chat",
      "GET https://clawd-inference-mesh.fly.dev/health",
      "GET https://clawd-inference-mesh.fly.dev/models",
      "POST https://clawd-inference-mesh.fly.dev/v1/chat/completions",
      "Ollama OpenAI-compatible local model runtime"
    ]
  },
  "mesh_endpoints": [
    {
      "method": "GET",
      "path": "/health",
      "url": "https://clawd-inference-mesh.fly.dev/health",
      "purpose": "Public health, active request count, peer count, and public inference toggle."
    },
    {
      "method": "GET",
      "path": "/models",
      "url": "https://clawd-inference-mesh.fly.dev/models",
      "purpose": "Public Ollama model inventory."
    },
    {
      "method": "GET",
      "path": "/mesh/visualization",
      "url": "https://clawd-inference-mesh.fly.dev/mesh/visualization",
      "purpose": "Combined node, model, mesh, job, and recent flow state for live visualization."
    },
    {
      "method": "GET",
      "path": "/flow",
      "url": "https://clawd-inference-mesh.fly.dev/flow",
      "purpose": "Recent chat/inference/warmup events."
    },
    {
      "method": "POST",
      "path": "/v1/chat/completions",
      "url": "https://clawd-inference-mesh.fly.dev/v1/chat/completions",
      "purpose": "OpenAI-compatible chat completion proxy to local Ollama models."
    }
  ],
  "zk_router_endpoints": [
    {
      "method": "GET",
      "path": "/health",
      "url": "https://clawdrouter-zk.fly.dev/health",
      "purpose": "Public router health, upstream families, wallet identity, and ZK/compression economics."
    },
    {
      "method": "GET",
      "path": "/v1/models",
      "url": "https://clawdrouter-zk.fly.dev/v1/models",
      "purpose": "OpenAI-compatible model registry including Ollama, OpenRouter, Redpill, xAI, and Fireworks routes."
    },
    {
      "method": "POST",
      "path": "/v1/chat/completions",
      "url": "https://clawdrouter-zk.fly.dev/v1/chat/completions",
      "purpose": "Protected smart-routing endpoint. Public site shows metadata only; it does not expose API keys."
    }
  ],
  "confirmed_models": [
    "8bit/solana-clawd-core-ai:latest",
    "8bit/solana-clawd-core-ai:preview",
    "8bit/solana-clawd-core-ai:1.5b-merged-20260620",
    "8bit/solana-clawd:preview",
    "8bit/solana-trading-factory:latest",
    "8bit/solana-trading-factory:preview",
    "8bit/solana-trading-factory:8b-lora-20260620",
    "8bit/DeepSolana:latest",
    "hermes3:8b",
    "qwen2.5:1.5b",
    "nemotron3:33b"
  ],
  "live_preview": {
    "default_model": "8bit/solana-clawd-core-ai:latest",
    "default_prompt": "Reply with exactly this sentence: Clawd mesh live: browser to Fly mesh to Ollama.",
    "safe_limits": {
      "max_tokens": 96,
      "temperature": 0.2,
      "stream": false
    }
  }
}
